# Premortem sponsor keys. Copy to .env and fill. Fixture mode needs NONE of these.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-8k

# Optional cheap DEV provider (keep the demo bake on Kimi for the sponsor score)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

BRIGHTDATA_API_KEY=
BRIGHTDATA_UNLOCKER_ZONE=
BRIGHTDATA_SERP_ZONE=
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
VIDEODB_API_KEY=
SENSENOVA_API_KEY=
TERMINAL3_API_KEY=

# runtime
PREMORTEM_MODE=fixture        # fixture | live
PYTHONIOENCODING=utf-8
